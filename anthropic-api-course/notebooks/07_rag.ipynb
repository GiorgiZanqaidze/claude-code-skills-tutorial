    "cell_type": "markdown",
    "metadata": {},
    "source": [
      "## Step 3 — Embedding (Simulated)\n",
      "\n",
      "Real RAG systems use embedding models (OpenAI, Cohere, or local). For this tutorial, we'll simulate embeddings using a simple hash-based approach that captures semantic similarity at a toy level.\n",
      "\n",
      "**In production**, replace this with a real embedding service (e.g., `client.embeddings.create(model=\"text-embedding-3-small\", input=text)`)."
    ]
  },
  {
    "cell_type": "code",
    "execution_count": null,
    "metadata": {},
    "outputs": [],
    "source": [
      "def simple_embedding(text: str, dim: int = 128) -> list[float]:\n",
      "    \"\"\"\n",
      "    Toy embedding: for each unique word in the text, set a dimension to the\n",
      "    word's frequency. This is NOT a real embedding but works for demo purposes.\n",
      "    \n",
      "    Real embeddings: use OpenAI text-embedding-3-small or similar.\n",
      "    \"\"\"\n",
      "    words = text.lower().split()\n",
      "    word_freq = {}\n",
      "    for word in words:\n",
      "        word = word.strip('.,!?;:')\n",
      "        word_freq[word] = word_freq.get(word, 0) + 1\n",
      "\n",
      "    # Create a fixed-size vector\n",
      "    vector = [0.0] * dim\n",
      "    for word, freq in word_freq.items():\n",
      "        # Deterministic hash of the word to pick a dimension\n",
      "        idx = hash(word) % dim\n",
      "        vector[idx] += freq\n",
      "\n",
      "    # Normalize\n",
      "    magnitude = math.sqrt(sum(v**2 for v in vector))\n",
      "    if magnitude > 0:\n",
      "        vector = [v / magnitude for v in vector]\n",
      "\n",
      "    return vector\n",
      "\n",
      "\n",
      "def cosine_similarity(v1: list[float], v2: list[float]) -> float:\n",
      "    \"\"\"Compute cosine similarity between two vectors.\"\"\"\n",
      "    dot = sum(a * b for a, b in zip(v1, v2))\n",
      "    mag1 = math.sqrt(sum(a**2 for a in v1))\n",
      "    mag2 = math.sqrt(sum(b**2 for b in v2))\n",
      "    if mag1 == 0 or mag2 == 0:\n",
      "        return 0.0\n",
      "    return dot / (mag1 * mag2)\n",
      "\n",
      "\n",
      "# Embed all chunks\n",
      "for chunk in chunks:\n",
      "    chunk[\"embedding\"] = simple_embedding(chunk[\"text\"])\n",
      "\n",
      "print(f\"Embedded {len(chunks)} chunks, each with 128-dim vector.\")"
    ]
  },
  {
    "cell_type": "markdown",
    "metadata": {},
    "source": [
      "## Step 4 — Retrieval (Similarity Search)\n",
      "\n",
      "Given a query, find the top-K chunks most similar to it."
    ]
  },
  {
    "cell_type": "code",
    "execution_count": null,
    "metadata": {},
    "outputs": [],
    "source": [
      "def retrieve(query: str, chunks: list[dict], top_k: int = 3) -> list[dict]:\n",
      "    \"\"\"\n",
      "    Retrieve the top-k most similar chunks for a query.\n",
      "    \"\"\"\n",
      "    query_embedding = simple_embedding(query)\n",
      "    scores = []\n",
      "\n",
      "    for chunk in chunks:\n",
      "        similarity = cosine_similarity(query_embedding, chunk[\"embedding\"])\n",
      "        scores.append((similarity, chunk))\n",
      "\n",
      "    # Sort by similarity, descending\n",
      "    scores.sort(key=lambda x: x[0], reverse=True)\n",
      "\n",
      "    # Return top-k, including scores\n",
      "    results = []\n",
      "    for similarity, chunk in scores[:top_k]:\n",
      "        results.append({**chunk, \"score\": similarity})\n",
      "\n",
      "    return results\n",
      "\n",
      "\n",
      "# Test retrieval\n",
      "test_query = \"How much does storage cost?\"\n",
      "results = retrieve(test_query, chunks, top_k=3)\n",
      "\n",
      "print(f\"Query: {test_query!r}\\n\")\n",
      "for i, result in enumerate(results, 1):\n",
      "    print(f\"  Result {i} (score={result['score']:.3f}, from {result['source']}):\")\n",
      "    print(f\"    {result['text'][:120]}...\")\n",
      "    print()"
    ]
  },
  {
    "cell_type": "markdown",
    "metadata": {},
    "source": [
      "## Step 5 — Augmentation: Format Retrieved Context\n",
      "\n",
      "Take the retrieved chunks and format them as context to pass to Claude."
    ]
  },
  {
    "cell_type": "code",
    "execution_count": null,
    "metadata": {},
    "outputs": [],
    "source": [
      "def format_context(retrieved_chunks: list[dict]) -> str:\n",
      "    \"\"\"\n",
      "    Take retrieved chunks and format them as a nicely readable context block.\n",
      "    \"\"\"\n",
      "    if not retrieved_chunks:\n",
      "        return \"(No relevant context found.)\"\n",
      "\n",
      "    lines = []\n",
      "    for chunk in retrieved_chunks:\n",
      "        lines.append(f\"From [{chunk['source']}]:\")\n",
      "        lines.append(chunk[\"text\"])\n",
      "        lines.append(\"\")\n",
      "\n",
      "    return \"\\n\".join(lines)\n",
      "\n",
      "\n",
      "context = format_context(results)\n",
      "print(\"Formatted context to pass to Claude:\")\n",
      "print(\"-\" * 60)\n",
      "print(context)"
    ]
  },
  {
    "cell_type": "markdown",
    "metadata": {},
    "source": [
      "## Step 6 — The RAG Loop\n",
      "\n",
      "Combine everything: user question → retrieve → augment → generate."
    ]
  },
  {
    "cell_type": "code",
    "execution_count": null,
    "metadata": {},
    "outputs": [],
    "source": [
      "def rag_answer(user_query: str, chunks: list[dict]) -> dict:\n",
      "    \"\"\"\n",
      "    Complete RAG pipeline: retrieve relevant chunks, format context,\n",
      "    ask Claude to answer based on that context.\n",
      "    \n",
      "    Returns {query, retrieved_chunks, answer}.\n",
      "    \"\"\"\n",
      "    # Step 1: Retrieve\n",
      "    retrieved = retrieve(user_query, chunks, top_k=3)\n",
      "    context = format_context(retrieved)\n",
      "\n",
      "    # Step 2: Build system prompt that grounds Claude in the context\n",
      "    system_prompt = f\"\"\"You are a helpful support assistant for SkyForge Cloud.\n",
      "\n",
      "Your job is to answer user questions about SkyForge's services, pricing, and features.\n",
      "Use ONLY the context provided below. If the answer is not in the context, say so.\n",
      "Do not make up pricing or features.\n",
      "\n",
      "CONTEXT:\n",
      "{context}\n",
      "\"\"\"\n",
      "\n",
      "    # Step 3: Ask Claude\n",
      "    response = client.messages.create(\n",
      "        model=model,\n",
      "        max_tokens=300,\n",
      "        system=system_prompt,\n",
      "        messages=[{\"role\": \"user\", \"content\": user_query}],\n",
      "    )\n",
      "\n",
      "    answer = response.content[0].text\n",
      "\n",
      "    return {\n",
      "        \"query\": user_query,\n",
      "        \"retrieved_chunks\": retrieved,\n",
      "        \"answer\": answer,\n",
      "    }\n",
      "\n",
      "\n",
      "# Test the full pipeline\n",
      "result = rag_answer(\"What storage billing is charged daily?\", chunks)\n",
      "print(f\"Query: {result['query']!r}\\n\")\n",
      "print(f\"Retrieved {len(result['retrieved_chunks'])} chunks.\\n\")\n",
      "print(f\"Answer:\\n{result['answer']}\")"
    ]
  },
