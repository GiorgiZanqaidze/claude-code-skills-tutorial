    "source": [
      "## Step 9 — Advanced: Multi-turn RAG Chat\n",
      "\n",
      "Extend the pipeline to a full conversation where retrieved context is maintained across turns."
    ]
  },
  {
    "cell_type": "code",
    "execution_count": null,
    "metadata": {},
    "outputs": [],
    "source": [
      "def rag_chatbot(user_message: str, messages: list, chunks: list[dict]) -> tuple[str, list]:\n",
      "    \"\"\"\n",
      "    Multi-turn RAG: retrieve once per user message, augment the system prompt,\n",
      "    maintain conversation history.\n",
      "    \"\"\"\n",
      "    # Retrieve based on the latest user message\n",
      "    retrieved = retrieve(user_message, chunks, top_k=3)\n",
      "    context = format_context(retrieved)\n",
      "\n",
      "    system_prompt = f\"\"\"You are a helpful support assistant for SkyForge Cloud.\n",
      "You are having a multi-turn conversation with a user.\n",
      "\n",
      "Use ONLY the context provided to answer questions about SkyForge.\n",
      "If information is not in the context, say you don't know.\n",
      "Be concise and helpful.\n",
      "\n",
      "CONTEXT:\n",
      "{context}\n",
      "\"\"\"\n",
      "\n",
      "    # Build message history\n",
      "    messages.append({\"role\": \"user\", \"content\": user_message})\n",
      "\n",
      "    response = client.messages.create(\n",
      "        model=model,\n",
      "        max_tokens=300,\n",
      "        system=system_prompt,\n",
      "        messages=messages,\n",
      "    )\n",
      "\n",
      "    answer = response.content[0].text\n",
      "    messages.append({\"role\": \"assistant\", \"content\": answer})\n",
      "\n",
      "    return answer, messages\n",
      "\n",
      "\n",
      "# Start a conversation\n",
      "print(\"=\" * 70)\n",
      "print(\"Starting multi-turn RAG conversation...\")\n",
      "print(\"=\" * 70)\n",
      "\n",
      "conversation = []\n",
      "\n",
      "# Turn 1\n",
      "q1 = \"What services does SkyForge offer?\"\n",
      "print(f\"\\nYou: {q1}\")\n",
      "a1, conversation = rag_chatbot(q1, conversation, chunks)\n",
      "print(f\"Bot: {a1}\")\n",
      "\n",
      "# Turn 2\n",
      "q2 = \"Tell me more about Edge. What regions does it cover?\"\n",
      "print(f\"\\nYou: {q2}\")\n",
      "a2, conversation = rag_chatbot(q2, conversation, chunks)\n",
      "print(f\"Bot: {a2}\")\n",
      "\n",
      "# Turn 3\n",
      "q3 = \"Is there a premium tier for Edge?\"\n",
      "print(f\"\\nYou: {q3}\")\n",
      "a3, conversation = rag_chatbot(q3, conversation, chunks)\n",
      "print(f\"Bot: {a3}\")"
    ]
  },
