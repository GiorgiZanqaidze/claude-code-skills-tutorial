      "## Step 2 — Chunking Strategy\n",
      "\n",
      "We'll use a simple but effective approach: split on headers, then further split if a section exceeds 500 characters. This keeps semantically related content together."
    ]
  },
  {
    "cell_type": "code",
    "execution_count": null,
    "metadata": {},
    "outputs": [],
    "source": [
      "def chunk_documents(text: str, max_chunk_size: int = 500) -> list[dict]:\n",
      "    \"\"\"\n",
      "    Split text into chunks by section headers (## markers).\n",
      "    If a section exceeds max_chunk_size, split it further by sentence.\n",
      "    Each chunk is returned as {text, source}.\n",
      "    \"\"\"\n",
      "    chunks = []\n",
      "    lines = text.strip().split(\"\\n\")\n",
      "    current_section = \"\"\n",
      "    current_header = \"Introduction\"\n",
      "\n",
      "    for line in lines:\n",
      "        if line.startswith(\"##\"):\n",
      "            # Save the previous section if it exists\n",
      "            if current_section.strip():\n",
      "                chunks.extend(\n",
      "                    _split_by_size(current_section, current_header, max_chunk_size)\n",
      "                )\n",
      "            # Start a new section\n",
      "            current_header = line.replace(\"##\", \"\").strip()\n",
      "            current_section = current_header + \"\\n\"\n",
      "        else:\n",
      "            current_section += line + \"\\n\"\n",
      "\n",
      "    # Don't forget the last section\n",
      "    if current_section.strip():\n",
      "        chunks.extend(_split_by_size(current_section, current_header, max_chunk_size))\n",
      "\n",
      "    return chunks\n",
      "\n",
      "\n",
      "def _split_by_size(\n",
      "    text: str, header: str, max_size: int\n",
      ") -> list[dict]:\n",
      "    \"\"\"If text > max_size, split by sentence; otherwise return as-is.\"\"\"\n",
      "    if len(text) <= max_size:\n",
      "        return [{\"text\": text, \"source\": header}]\n",
      "\n",
      "    # Split by period, keeping the period\n",
      "    sentences = [s.strip() + \".\" for s in text.split(\".\") if s.strip()]\n",
      "    chunks = []\n",
      "    current = \"\"\n",
      "\n",
      "    for sent in sentences:\n",
      "        if len(current) + len(sent) <= max_size:\n",
      "            current += \" \" + sent if current else sent\n",
      "        else:\n",
      "            if current:\n",
      "                chunks.append({\"text\": current, \"source\": header})\n",
      "            current = sent\n",
      "\n",
      "    if current:\n",
      "        chunks.append({\"text\": current, \"source\": header})\n",
      "\n",
      "    return chunks\n",
      "\n",
      "\n",
      "chunks = chunk_documents(PRODUCT_DOCS)\n",
      "print(f\"Created {len(chunks)} chunks:\")\n",
      "for i, chunk in enumerate(chunks[:5], 1):\n",
      "    print(f\"\\n  Chunk {i} (from {chunk['source']}):\")\n",
      "    print(f\"    {chunk['text'][:100]}...\")"
    ]
  },
