{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Read(todos.md)",
      "Read(audit.log)",
      "Edit(todos.md)",
      "Bash(powershell:*)"
    ],
    "deny": [
      "WebFetch",
      "WebSearch"
    ]
  },
  "env": {
    "TODO_FILE": "todos.md",
    "AUDIT_LOG": "audit.log"
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -Command \"$payload = $input | Out-String | ConvertFrom-Json; if ($payload.tool_input.file_path -match 'todos\\.md$') { Add-Content -Path audit.log -Value ($([DateTime]::UtcNow.ToString('o')) + ' edited todos.md via ' + $payload.tool_name) }\""
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -Command \"Add-Content -Path audit.log -Value ($([DateTime]::UtcNow.ToString('o')) + ' user prompt submitted')\""
          }
        ]
      }
    ]
  }
}
